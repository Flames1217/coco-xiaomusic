{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "coco-xiaomusic",
  "version": "0.1.0",
  "identifier": "top.viper3.coco-xiaomusic",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "title": "coco-xiaomusic",
        "width": 1480,
        "height": 840,
        "minWidth": 1180,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../assets/logo.ico", "../assets/logo.png"],
    "resources": ["../sidecar"]
  }
}
